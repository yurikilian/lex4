{
  "name": "@yurikilian/lex4",
  "version": "0.2.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yurikilian/lex4.git",
    "directory": "packages/editor"
  },
  "homepage": "https://yurikilian.github.io/lex4/",
  "bugs": {
    "url": "https://github.com/yurikilian/lex4/issues"
  },
  "keywords": [
    "react",
    "editor",
    "lexical",
    "document",
    "paginated",
    "a4",
    "word-processor",
    "rich-text"
  ],
  "description": "A paginated document editor — reusable React library built on Meta Lexical",
  "type": "module",
  "main": "./dist/lex4-editor.cjs",
  "module": "./dist/lex4-editor.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lex4-editor.js",
      "require": "./dist/lex4-editor.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@lexical/clipboard": "^0.22.0",
    "@lexical/history": "^0.22.0",
    "@lexical/html": "^0.22.0",
    "@lexical/list": "^0.22.0",
    "@lexical/react": "^0.22.0",
    "@lexical/rich-text": "^0.22.0",
    "@lexical/selection": "^0.22.0",
    "@lexical/utils": "^0.22.0",
    "lexical": "^0.22.0",
    "lucide-react": "^1.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
